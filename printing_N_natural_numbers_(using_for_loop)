// printing N natural numbers using for loop where N is user input

#include <stdio.h>
int main(){
    int N;
    int i;

    printf("Enter the number N: ");
    scanf("%d", &N);

    if(N>0){
        for ( i = 1; i <= N ; i++){
        printf("%d ",i);
        printf("\n");
        }
    }

    else if(N<0){
        printf("Enter a positive integer\n");
    }

    else {
        printf("Enter a positive integer\n");
    }
    return 0;
}
